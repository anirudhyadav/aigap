{
  "name": "aigap",
  "displayName": "aigap — AI Guardrails and Policies",
  "description": "Define once. Enforce everywhere. Audit always. Convert policy docs into versioned guardrail specs, generate enforcement stubs, and gate every PR.",
  "version": "0.1.0",
  "publisher": "anirudhyadav",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/anirudhyadav/aigap"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["Other", "Linters", "Testing"],
  "keywords": ["ai", "guardrails", "policy", "compliance", "llm", "copilot"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "aigap.init",
        "title": "aigap: Initialize from Policy Doc",
        "category": "aigap"
      },
      {
        "command": "aigap.update",
        "title": "aigap: Add New Guardrail",
        "category": "aigap"
      },
      {
        "command": "aigap.validate",
        "title": "aigap: Validate POLICIES.md",
        "category": "aigap"
      },
      {
        "command": "aigap.gapReport",
        "title": "aigap: Show Gap Report",
        "category": "aigap"
      },
      {
        "command": "aigap.enforcement",
        "title": "aigap: Generate Enforcement Stubs",
        "category": "aigap"
      },
      {
        "command": "aigap.auditReport",
        "title": "aigap: Generate Audit Report",
        "category": "aigap"
      },
      {
        "command": "aigap.changeImpact",
        "title": "aigap: Analyse Policy Change Impact",
        "category": "aigap"
      },
      {
        "command": "aigap.frameworkMap",
        "title": "aigap: Map Regulation Frameworks",
        "category": "aigap"
      },
      {
        "command": "aigap.sprintFeed",
        "title": "aigap: Generate Sprint Feed",
        "category": "aigap"
      },
      {
        "command": "aigap.prDraft",
        "title": "aigap: Draft Pull Request Description",
        "category": "aigap"
      },
      {
        "command": "aigap.releaseNotes",
        "title": "aigap: Generate Release Notes",
        "category": "aigap"
      },
      {
        "command": "aigap.statusReport",
        "title": "aigap: Generate Policy Status Report",
        "category": "aigap"
      },
      {
        "command": "aigap.staleness",
        "title": "aigap: Check Policy Staleness",
        "category": "aigap"
      },
      {
        "command": "aigap.testLinkage",
        "title": "aigap: Link Policies to Test Files",
        "category": "aigap"
      },
      {
        "command": "aigap.ingestConfluence",
        "title": "aigap: Ingest from Confluence",
        "category": "aigap"
      }
    ],
    "chatParticipants": [
      {
        "id": "aigap.participant",
        "name": "aigap",
        "description": "Ask anything about your AI policy coverage — unenforced rules, framework gaps, sprint tasks.",
        "isSticky": false,
        "commands": [
          {
            "name": "gaps",
            "description": "List all unenforced GP-NNN policies in the workspace"
          },
          {
            "name": "status",
            "description": "Show overall policy compliance status"
          },
          {
            "name": "task",
            "description": "Generate a sprint task for a specific GP-NNN"
          }
        ]
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "aigap.policyExplorer",
          "name": "aigap Policies",
          "contextualTitle": "aigap"
        }
      ]
    },
    "configuration": {
      "title": "aigap",
      "properties": {
        "aigap.preferredModel": {
          "type": "string",
          "default": "claude-sonnet-4-6",
          "description": "Copilot model to use for policy analysis",
          "enum": ["claude-haiku-4-5", "claude-sonnet-4-6", "claude-opus-4-7"]
        },
        "aigap.maxChunkTokens": {
          "type": "number",
          "default": 6000,
          "minimum": 1000,
          "maximum": 32000,
          "description": "Maximum tokens per policy chunk sent to the model"
        },
        "aigap.confluenceBaseUrl": {
          "type": "string",
          "default": "",
          "description": "Confluence base URL for the ingestConfluence command (e.g. https://yourorg.atlassian.net/wiki)"
        },
        "aigap.strictMode": {
          "type": "boolean",
          "default": false,
          "description": "When true, CI fails if any GP-NNN referenced in changed files has no enforcement stub"
        },
        "aigap.auditRetentionDays": {
          "type": "number",
          "default": 90,
          "minimum": 1,
          "description": "Number of days to retain audit log entries in audit-report.md"
        }
      }
    },
    "menus": {
      "commandPalette": [
        {
          "command": "aigap.gapReport",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "aigap.validate",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "aigap.enforcement",
          "when": "workspaceFolderCount > 0"
        }
      ],
      "editor/context": [
        {
          "command": "aigap.gapReport",
          "when": "resourceExtname =~ /\\.(py|ts|js|java|go)$/",
          "group": "aigap@1"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "lint": "eslint src --ext ts"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^2.27.0",
    "typescript": "^5.4.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0"
  }
}
