{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/anirudhyadav/aigap/schemas/aigap-policy.schema.json",
  "title": "AIGAP Policy Configuration",
  "description": "Schema for .aigap-policy.yaml files used by the aigap CLI and VS Code extension",
  "type": "object",
  "required": ["name", "rules"],
  "properties": {
    "version": {
      "type": "string",
      "default": "1",
      "description": "Schema version"
    },
    "name": {
      "type": "string",
      "description": "Human-readable name for this policy set"
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/PolicyRule"
      },
      "description": "List of guardrail/policy rules"
    },
    "block_on": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["critical", "high", "medium", "low"]
      },
      "default": ["critical", "high"],
      "description": "Severities that cause aigap check to exit non-zero"
    },
    "drift_threshold_pct": {
      "type": "number",
      "minimum": 0,
      "exclusiveMinimum": true,
      "default": 5.0,
      "description": "Percentage drop in pass-rate that triggers a drift alert"
    }
  },
  "$defs": {
    "PolicyRule": {
      "type": "object",
      "required": ["id", "name", "description", "category", "severity"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9\\-]*[a-z0-9]$",
          "description": "Unique rule ID (lowercase alphanumeric with hyphens)"
        },
        "name": {
          "type": "string",
          "description": "Short human-readable rule name"
        },
        "description": {
          "type": "string",
          "description": "Precise, enforceable description of the rule"
        },
        "category": {
          "type": "string",
          "enum": ["guardrail", "policy"],
          "description": "Rule type: guardrail (safety) or policy (business)"
        },
        "severity": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low"],
          "default": "high",
          "description": "How severe a violation is"
        },
        "plugin": {
          "type": "string",
          "description": "Fully-qualified plugin class (e.g. aigap.plugins.builtins.pii_leakage:PiiLeakagePlugin)"
        },
        "params": {
          "type": "object",
          "additionalProperties": true,
          "description": "Arbitrary parameters forwarded to the plugin constructor"
        },
        "fast_patterns": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Regex patterns for fast-path matching (skip LLM when matched)"
        },
        "required_test_tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Tags that must appear on GoldenPairs for coverage"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
